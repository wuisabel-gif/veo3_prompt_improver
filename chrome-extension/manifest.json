{
  "manifest_version": 3,
  "name": "Veo 3 Prompt Studio — Be Your Own Director",
  "version": "1.0.0",
  "description": "Transform rough ideas into structured, ultra-cinematic Veo 3 prompts using curated visual models and generation controls.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Veo 3 Prompt Studio"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
