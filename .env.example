# Gemini API configuration
# Copy this file to .env, then replace the placeholder key with your own Gemini API key.
CREATIVE_API_KEY=your_gemini_api_key_here
CREATIVE_MODEL=gemini-2.5-flash

# Local backend configuration
AVR_BACKEND_PORT=8787
HOST=127.0.0.1

# Optional Cloudinary upload configuration
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=veo3-prompt-improver
